source "https://rubygems.org"

# Web framework
gem "rails"

# Database
gem "pg"
gem "mysql2"

# Background processing
gem "sidekiq"
gem "redis"

# XML / HTML parsing (native extensions)
gem "nokogiri"

# JSON + serialization
gem "oj"

# Cryptography
gem "bcrypt"
gem "ruby-jwt"

# HTTP clients
gem "httparty"
gem "faraday"

# AWS SDK (large dependency tree)
gem "aws-sdk-s3"
gem "aws-sdk-secretsmanager"

# File processing
gem "mini_magick"

# Logging & monitoring
gem "lograge"

# Testing framework (adds dev dependencies)
group :development, :test do
  gem "rspec"
  gem "factory_bot"
  gem "faker"
end

